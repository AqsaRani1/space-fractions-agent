.env.example

# Database connection URL
DATABASE_URL=postgresql://username:password@host:port/database_name

# Redis connection URL
REDIS_URL=redis://host:port

# Secret key for Flask app
SECRET_KEY=your_secret_key_here

# URL for external Question service
QUESTION_SERVICE_URL=http://question-service.example.com

# URL for external User service
USER_SERVICE_URL=http://user-service.example.com

# Port for Flask app to listen on
PORT=5000

# Debug mode setting
DEBUG=False

# Secret key for JWT token signing
JWT_SECRET=your_jwt_secret_here